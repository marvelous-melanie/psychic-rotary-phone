---
import type { CollectionEntry } from 'astro:content';
import GalleryCard from './GalleryCard.astro';
import { getGalleryCover } from '../lib/galleries';

interface Props {
  galleries: CollectionEntry<'galleries'>[];
}

const { galleries } = Astro.props;
---

<div class:list={[
  'grid gap-4',
  galleries.length === 1 ? 'grid-cols-1 max-w-lg mx-auto' : 'sm:grid-cols-2',
]}>
  {galleries.map((gallery) => {
    const cover = getGalleryCover(gallery.id, gallery.data.cover);
    return <GalleryCard gallery={gallery} cover={cover} />;
  })}
</div>
