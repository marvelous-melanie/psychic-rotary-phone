---
import { Image } from 'astro:assets';
import { withBase } from '../lib/paths';
import logo from '../assets/logo.jpg';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const normalizePath = (path: string) => withBase(path).replace(/\/$/, '') || '/';
const isActive = (path: string) => normalizePath(path) === currentPath;
const isPortfolioActive = ['/engagements/', '/graduations/'].some((p) => isActive(p));

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="bg-green-deep text-cream">
  <div class="flex flex-col items-center px-4 pb-6 pt-8">

    <!-- Logo -->
    <a href={withBase('/')} aria-label="Elm City Photography — home">
      <Image
        src={logo}
        alt="Elm City Photography"
        width={88}
        height={88}
        class="h-22 w-22 rounded-full object-cover ring-2 ring-gold/40 transition-opacity hover:opacity-85"
      />
    </a>

    <!-- Business name -->
    <p class="mt-3 font-serif text-sm italic tracking-wide text-cream/80">Elm City Photography</p>

    <div class="mt-4 w-12 border-t border-gold/35"></div>

    <!-- Nav -->
    <nav aria-label="Primary" class="mt-4">
      <ul class="flex flex-wrap items-center justify-center gap-x-1 text-[11px] font-medium uppercase tracking-[0.28em]">
        {navLinks.map((link) => (
          <li>
            <a
              href={withBase(link.href)}
              class:list={[
                'px-3 py-1 transition-colors',
                isActive(link.href) ? 'text-gold' : 'text-cream/80 hover:text-cream',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}

        <!-- Portfolio dropdown -->
        <li class="relative group">
          <button
            type="button"
            class:list={[
              'flex cursor-default items-center gap-1 px-3 py-1 uppercase transition-colors',
              isPortfolioActive ? 'text-gold' : 'text-cream/80 group-hover:text-cream',
            ]}
          >
            Portfolio
            <svg width="8" height="5" viewBox="0 0 8 5" fill="currentColor" aria-hidden="true">
              <path d="M0 0l4 5 4-5z" />
            </svg>
          </button>
          <!--
            The dropdown uses pt-2 (padding) instead of mt-2 (margin) so there is
            no gap between the button and the list — closing the dead zone that
            caused the menu to vanish when mousing downward toward the items.
          -->
          <ul class="pointer-events-none absolute left-1/2 top-full z-50 w-44 -translate-x-1/2 rounded border border-green-light/20 bg-green-deep pt-2 pb-1 opacity-0 shadow-xl transition-all duration-150 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
            <li>
              <a href={withBase('/engagements/')} class="block px-4 py-2.5 text-[11px] uppercase tracking-[0.22em] text-cream/80 hover:bg-green-mid/50 hover:text-cream">
                Engagements
              </a>
            </li>
            <li>
              <a href={withBase('/graduations/')} class="block px-4 py-2.5 text-[11px] uppercase tracking-[0.22em] text-cream/80 hover:bg-green-mid/50 hover:text-cream">
                Graduations
              </a>
            </li>
          </ul>
        </li>
      </ul>
    </nav>

  </div>
</header>
