---
import { Image } from 'astro:assets';
import { withBase } from '../lib/paths';
import logo from '../assets/logo.jpg';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const normalizePath = (path: string) => withBase(path).replace(/\/$/, '') || '/';
const isActive = (path: string) => normalizePath(path) === currentPath;
const isPortfolioActive = ['/engagements/', '/graduations/'].some((p) => isActive(p));
const isPricingActive = ['/pricing/', '/engagement-pricing/'].some((p) => isActive(p));

function linkClass(active: boolean) {
  return ['px-3 py-1 transition-colors', active ? 'text-gold' : 'text-cream/80 hover:text-cream'].join(' ');
}
---

<header class="bg-green-deep text-cream">
  <div class="flex flex-col items-center px-4 pb-6 pt-8">

    <a href={withBase('/')} aria-label="Elm City Photography home">
      <Image
        src={logo}
        alt="Elm City Photography"
        width={88}
        height={88}
        class="h-22 w-22 rounded-full object-cover ring-2 ring-gold/40 transition-opacity hover:opacity-85"
      />
    </a>

    <p class="mt-3 font-serif text-sm italic tracking-wide text-cream/80">Elm City Photography</p>

    <div class="mt-4 w-12 border-t border-gold/35"></div>

    <nav aria-label="Primary" class="mt-4">
      <ul class="flex flex-wrap items-center justify-center gap-x-1 text-xs font-medium uppercase tracking-[0.28em]">

        <li>
          <a href={withBase('/')} class={linkClass(isActive('/'))}>Home</a>
        </li>

        <li>
          <a href={withBase('/about/')} class={linkClass(isActive('/about/'))}>About</a>
        </li>

        <!-- Portfolio dropdown, sits between About and Pricing -->
        <li class="relative group">
          <button
            type="button"
            class:list={[
              'flex cursor-default items-center gap-1 px-3 py-1 uppercase transition-colors',
              isPortfolioActive ? 'text-gold' : 'text-cream/80 group-hover:text-cream',
            ]}
          >
            Portfolio
            <svg width="8" height="5" viewBox="0 0 8 5" fill="currentColor" aria-hidden="true">
              <path d="M0 0l4 5 4-5z" />
            </svg>
          </button>
          <ul class="pointer-events-none absolute left-1/2 top-full z-50 w-44 -translate-x-1/2 rounded border border-green-light/20 bg-green-deep pb-1 pt-2 opacity-0 shadow-xl transition-all duration-150 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
            <li>
              <a href={withBase('/engagements/')} class="block px-4 py-2.5 text-xs uppercase tracking-[0.22em] text-cream/80 hover:bg-green-mid/50 hover:text-cream">
                Engagements
              </a>
            </li>
            <li>
              <a href={withBase('/graduations/')} class="block px-4 py-2.5 text-xs uppercase tracking-[0.22em] text-cream/80 hover:bg-green-mid/50 hover:text-cream">
                Graduations
              </a>
            </li>
          </ul>
        </li>

        <!-- Pricing dropdown -->
        <li class="relative group">
          <button
            type="button"
            class:list={[
              'flex cursor-default items-center gap-1 px-3 py-1 uppercase transition-colors',
              isPricingActive ? 'text-gold' : 'text-cream/80 group-hover:text-cream',
            ]}
          >
            Pricing
            <svg width="8" height="5" viewBox="0 0 8 5" fill="currentColor" aria-hidden="true">
              <path d="M0 0l4 5 4-5z" />
            </svg>
          </button>
          <ul class="pointer-events-none absolute left-1/2 top-full z-50 w-44 -translate-x-1/2 rounded border border-green-light/20 bg-green-deep pb-1 pt-2 opacity-0 shadow-xl transition-all duration-150 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
            <li>
              <a href={withBase('/pricing/')} class="block px-4 py-2.5 text-xs uppercase tracking-[0.22em] text-cream/80 hover:bg-green-mid/50 hover:text-cream">
                Weddings
              </a>
            </li>
            <li>
              <a href={withBase('/engagement-pricing/')} class="block px-4 py-2.5 text-xs uppercase tracking-[0.22em] text-cream/80 hover:bg-green-mid/50 hover:text-cream">
                Engagements
              </a>
            </li>
          </ul>
        </li>

        <li>
          <a href={withBase('/contact/')} class={linkClass(isActive('/contact/'))}>Contact</a>
        </li>

      </ul>
    </nav>

  </div>
</header>
