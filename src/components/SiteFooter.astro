---
import { Instagram, Mail } from 'lucide-astro';
---

<footer class="border-t border-green-light/30 bg-green-deep px-4 py-6 text-sm text-cream">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 text-center sm:flex-row sm:items-center sm:justify-between">
    <p>Elm City Photography</p>
    <div class="flex items-center gap-6">
      <a
        href="mailto:hello@elmcityphotography.com"
        class="flex items-center gap-2 text-green-light transition-colors hover:text-cream/80"
        aria-label="Email us"
      >
        <Mail size={16} />
        <span>hello@elmcityphotography.com</span>
      </a>
      <a
        href="https://www.instagram.com/elm.city.photography"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-green-light transition-colors hover:text-cream/80"
        aria-label="Follow us on Instagram"
      >
        <Instagram size={16} />
        <span>@elm.city.photography</span>
      </a>
    </div>
    <p class="text-green-light">{new Date().getFullYear()}</p>
  </div>
</footer>
