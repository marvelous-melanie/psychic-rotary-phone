---
import { getCollection } from 'astro:content';
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';

const galleries = (await getCollection('galleries'))
  .filter((gallery) => gallery.data.type === 'graduation')
  .sort((a, b) => a.data.order - b.data.order);
---

<MarketingPageLayout title="Graduation Portraits — Elm City Photography" description="Graduation portrait photography in New Haven, CT.">
  <h1 class="text-4xl font-medium">Graduation Portraits</h1>
  <p class="mt-2 max-w-2xl text-sm text-muted">Celebrating your milestone in New Haven, CT.</p>
  <div class="mt-8">
    <GalleryGrid galleries={galleries} />
  </div>
</MarketingPageLayout>
