---
import { getCollection } from 'astro:content';
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';

const galleries = (await getCollection('galleries'))
  .filter((gallery) => gallery.data.type === 'graduation')
  .sort((a, b) => a.data.order - b.data.order);
---

<MarketingPageLayout title="Graduation Portraits — Elm City Photography" description="Graduation portrait photography in New Haven, CT.">
  <section class="mb-8 -mx-4 bg-green-deep px-4 py-8">
    <p class="text-xs uppercase tracking-[0.26em] text-green-light">Milestone portraits & celebrations</p>
    <h1 class="mt-2 text-4xl text-cream">GRADUATION PORTFOLIO</h1>
    <p class="mt-3 max-w-3xl text-sm text-green-light">
      A celebration of achievement and transition, featuring expressive portraits crafted with editorial detail and a soft, natural
      Connecticut backdrop.
    </p>
  </section>
  <div class="mt-8">
    <GalleryGrid galleries={galleries} />
  </div>
</MarketingPageLayout>
