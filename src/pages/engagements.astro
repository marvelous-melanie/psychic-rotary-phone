---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';

const galleries = (await getCollection('galleries'))
  .filter((g) => g.data.type === 'engagement')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Engagements — Elm City Photography"
  description="Engagement photography from New Haven, CT. Natural light, honest moments, and images you'll keep for a lifetime."
>

  <div class="bg-green-deep px-6 py-24 text-center">
    <p class="text-xs uppercase tracking-[0.38em] text-green-light/70">Portfolio</p>
    <h1 class="mt-4 font-serif text-5xl italic text-cream md:text-6xl">Engagements</h1>
    <p class="mx-auto mt-5 max-w-sm text-sm leading-7 text-green-light/70">
      Intimate, unhurried sessions in Connecticut's parks, coastlines, and city streets.
      No stiff posing — just the two of you, in the light.
    </p>
  </div>

  <div class="bg-cream px-6 py-16">
    <div class="mx-auto max-w-5xl">
      <GalleryGrid galleries={galleries} />
    </div>
  </div>

</BaseLayout>
