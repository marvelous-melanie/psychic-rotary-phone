---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LightboxGallery from '../components/LightboxGallery.astro';
import { getGalleryImages } from '../lib/galleries';
import { withBase } from '../lib/paths';

const galleries = await getCollection('galleries');
const gallery = galleries
  .filter((g) => g.data.type === 'engagement')
  .sort((a, b) => a.data.order - b.data.order)[0];

const images = gallery ? getGalleryImages(gallery.id) : [];
---

<BaseLayout
  title="Engagement Photographer New Haven CT | Portfolio | Elm City Photography"
  description="Engagement session photography in New Haven, CT. Natural light, honest moments — view our portfolio of Connecticut couples."
>

  <div class="bg-green-deep px-6 py-12 text-center">
    <p class="text-xs uppercase tracking-[0.38em] text-green-light/70">Portfolio</p>
    <h1 class="mt-4 font-serif text-5xl italic text-cream md:text-6xl">Engagements</h1>
    <p class="mx-auto mt-5 max-w-sm text-sm leading-7 text-green-light/70">
      Intimate, unhurried sessions in Connecticut's parks, coastlines, and city streets.
      No stiff posing. Just the two of you, in the light.
    </p>
  </div>

  <div class="bg-cream pt-12">
    <LightboxGallery images={images} galleryId={gallery?.id ?? 'engagements'} />
  </div>

  <section class="bg-cream px-6 py-24 text-center">
    <p class="text-xs uppercase tracking-[0.35em] text-muted">Work together</p>
    <h2 class="mt-4 font-serif text-4xl italic text-ink md:text-5xl">Ready to book?</h2>
    <p class="mx-auto mt-5 max-w-sm text-base leading-7 text-muted">
      Tell us about your plans and we'll get back to you within 48 hours.
    </p>
    <a
      href={withBase('/contact/')}
      class="mt-8 inline-block bg-green-deep px-10 py-3.5 text-xs uppercase tracking-[0.28em] text-cream transition-colors hover:bg-green-mid"
    >
      Book with Us
    </a>
  </section>

</BaseLayout>
