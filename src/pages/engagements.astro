---
import { getCollection } from 'astro:content';
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';

const galleries = (await getCollection('galleries'))
  .filter((gallery) => gallery.data.type === 'engagement')
  .sort((a, b) => a.data.order - b.data.order);
---

<MarketingPageLayout title="Engagements" description="Engagement galleries.">
  <section class="mb-8 -mx-4 bg-green-deep px-4 py-8">
    <p class="text-xs uppercase tracking-[0.26em] text-green-light">Nature-forward engagement portraits</p>
    <h1 class="mt-2 text-4xl text-cream">ENGAGEMENTS</h1>
    <p class="mt-3 max-w-3xl text-sm text-green-light">
      Explore editorial engagement sessions rooted in natural moments, soft textures, and the warm, earthy tones of New Haven&apos;s
      coast and city streets.
    </p>
  </section>
  <div class="mt-8">
    <GalleryGrid galleries={galleries} />
  </div>
</MarketingPageLayout>
