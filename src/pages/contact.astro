---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Elm City Photography"
  description="Reach out to Elm City Photography to book a wedding, engagement, or portrait session in New Haven, CT."
>
  <div class="bg-cream">

    <div class="mx-auto max-w-2xl px-6 pb-8 pt-24">
      <p class="text-xs uppercase tracking-[0.38em] text-muted">Get in Touch</p>
      <h1 class="mt-4 font-serif text-5xl italic leading-tight text-ink md:text-6xl">Let's talk.</h1>
      <p class="mt-6 text-base leading-8 text-muted">
        Whether you're planning a wedding, an engagement session, or a graduation portrait,
        we'd love to hear about it. Fill out the form below or email us directly at{' '}
        <a href="mailto:hello@elmcityphotography.com" class="text-ink underline underline-offset-4 hover:text-green-mid transition-colors">
          hello@elmcityphotography.com
        </a>.
        We get back to every inquiry within 48 hours.
      </p>
    </div>

    <form class="mx-auto max-w-2xl px-6 pb-24 pt-10" action="https://formspree.io/f/xlgkvkez" method="post">
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="mb-2 block text-xs uppercase tracking-[0.28em] text-muted">Your Name</label>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            class="w-full border-b border-green-light bg-transparent py-3 text-sm text-ink placeholder-muted/50 outline-none transition-colors focus:border-ink"
            placeholder="Jane & John"
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-xs uppercase tracking-[0.28em] text-muted">Email Address</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            class="w-full border-b border-green-light bg-transparent py-3 text-sm text-ink placeholder-muted/50 outline-none transition-colors focus:border-ink"
            placeholder="you@example.com"
          />
        </div>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div>
          <label for="event-type" class="mb-2 block text-xs uppercase tracking-[0.28em] text-muted">Type of Session</label>
          <select
            id="event-type"
            name="event-type"
            class="w-full border-b border-green-light bg-transparent py-3 text-sm text-ink outline-none transition-colors focus:border-ink"
          >
            <option value="">Select one…</option>
            <option>Wedding</option>
            <option>Engagement</option>
            <option>Graduation</option>
            <option>Portrait</option>
            <option>Something else</option>
          </select>
        </div>
        <div>
          <label for="event-date" class="mb-2 block text-xs uppercase tracking-[0.28em] text-muted">Date (if you have one)</label>
          <input
            id="event-date"
            name="event-date"
            type="text"
            class="w-full border-b border-green-light bg-transparent py-3 text-sm text-ink placeholder-muted/50 outline-none transition-colors focus:border-ink"
            placeholder="Month DD, YYYY"
          />
        </div>
      </div>

      <div class="mt-8">
        <label for="message" class="mb-2 block text-xs uppercase tracking-[0.28em] text-muted">Tell Us About Your Day</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          class="w-full resize-none border-b border-green-light bg-transparent py-3 text-sm text-ink placeholder-muted/50 outline-none transition-colors focus:border-ink"
          placeholder="The venue, the vibe, what matters most to you. Whatever feels relevant."
        ></textarea>
      </div>

      <div class="mt-10">
        <button
          type="submit"
          class="bg-green-deep px-10 py-3.5 text-xs uppercase tracking-[0.28em] text-cream transition-colors hover:bg-green-mid"
        >
          Send Message
        </button>
        <p class="mt-4 text-xs text-muted/60">We'll get back to you within 48 hours.</p>
      </div>
    </form>

  </div>
</BaseLayout>
