---
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
---

<MarketingPageLayout title="Contact" description="Contact Elm City Photography.">
  <h1 class="text-4xl font-medium">Contact</h1>
  <p class="mt-2 max-w-2xl text-sm text-muted">Placeholder contact form for static layout only.</p>

  <form class="mt-6 max-w-xl space-y-4" action="#" method="post">
    <div>
      <label for="name" class="mb-1 block text-sm">Name</label>
      <input id="name" name="name" type="text" class="w-full border border-black/20 p-2" placeholder="Your name" />
    </div>

    <div>
      <label for="email" class="mb-1 block text-sm">Email</label>
      <input id="email" name="email" type="email" class="w-full border border-black/20 p-2" placeholder="you@example.com" />
    </div>

    <div>
      <label for="message" class="mb-1 block text-sm">Message</label>
      <textarea id="message" name="message" rows="5" class="w-full border border-black/20 p-2" placeholder="Tell us about your event"></textarea>
    </div>

    <button class="rounded border border-black/25 px-4 py-2" type="submit">Send</button>
  </form>
</MarketingPageLayout>
