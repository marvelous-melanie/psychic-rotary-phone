---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';

const packages = [
  {
    name: 'The Essential',
    price: '$350',
    description: 'A focused session for those who want beautiful, edited portraits without the extras.',
    items: [
      '1-hour session',
      '30 edited digital photos',
      'Online gallery delivery',
      'Personal print release',
    ],
    featured: false,
  },
  {
    name: 'The Story',
    price: '$650',
    description: 'Our most popular package — time and space to tell your story with depth and ease.',
    items: [
      '2-hour session',
      '75+ edited digital photos',
      'Online gallery delivery',
      'Personal print release',
      'One 5×7 fine-art print',
    ],
    featured: true,
  },
  {
    name: 'The Full Day',
    price: '$1,100',
    description: 'For milestones that deserve to be documented from every angle, in every light.',
    items: [
      'Up to 6 hours',
      '150+ edited digital photos',
      'Online gallery delivery',
      'Personal print release',
      '8×10 framed fine-art print',
      'Second location included',
    ],
    featured: false,
  },
];
---

<BaseLayout title="Pricing — Elm City Photography" description="Session packages and pricing for Elm City Photography in New Haven, CT.">

  <div class="bg-cream">
    <!-- Page header -->
    <div class="mx-auto max-w-2xl px-6 pb-16 pt-24 text-center">
      <p class="text-[10px] uppercase tracking-[0.38em] text-muted">Investment</p>
      <h1 class="mt-4 font-serif text-5xl italic leading-tight text-ink md:text-6xl">Packages</h1>
      <p class="mx-auto mt-5 max-w-sm text-sm leading-7 text-muted">
        Three thoughtful options for engagements, graduations, and portrait sessions in the New Haven area.
      </p>
    </div>

    <!-- Package cards -->
    <div class="mx-auto grid max-w-5xl gap-px px-6 pb-6 sm:grid-cols-3 sm:px-6">
      {packages.map((pkg) => (
        <article class:list={[
          'flex flex-col px-8 py-12',
          pkg.featured
            ? 'bg-green-deep text-cream'
            : 'bg-white text-ink',
        ]}>
          {pkg.featured && (
            <p class="mb-6 self-start border border-gold/60 px-3 py-1 text-[9px] uppercase tracking-[0.3em] text-gold">
              Most Popular
            </p>
          )}
          <p class:list={[
            'text-[10px] uppercase tracking-[0.28em]',
            pkg.featured ? 'text-green-light/70' : 'text-muted',
          ]}>
            {pkg.name}
          </p>
          <p class:list={[
            'mt-3 font-serif text-5xl italic',
            pkg.featured ? 'text-cream' : 'text-ink',
          ]}>
            {pkg.price}
          </p>
          <p class:list={[
            'mt-4 text-xs leading-6',
            pkg.featured ? 'text-green-light/80' : 'text-muted',
          ]}>
            {pkg.description}
          </p>
          <ul class:list={[
            'mt-8 space-y-3 text-xs',
            pkg.featured ? 'text-green-light' : 'text-muted',
          ]}>
            {pkg.items.map((item) => (
              <li class="flex items-start gap-3">
                <span class:list={['mt-px text-base leading-none', pkg.featured ? 'text-gold' : 'text-green-mid']}>·</span>
                {item}
              </li>
            ))}
          </ul>
          <div class="mt-auto pt-10">
            <a
              href={withBase('/contact/')}
              class:list={[
                'inline-block text-[10px] uppercase tracking-[0.28em] transition-colors',
                pkg.featured
                  ? 'border-b border-gold/60 pb-px text-gold hover:border-gold'
                  : 'border-b border-ink/30 pb-px text-ink hover:border-ink',
              ]}
            >
              Book This →
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer note -->
    <div class="mx-auto max-w-5xl px-6 pb-24 pt-10 text-center">
      <p class="text-xs leading-7 text-muted">
        All packages include travel within the New Haven, CT area.<br />
        Reach out for destination sessions, custom requests, or wedding inquiries.
      </p>
      <a
        href={withBase('/contact/')}
        class="mt-8 inline-block bg-green-deep px-10 py-3.5 text-[11px] uppercase tracking-[0.28em] text-cream transition-colors hover:bg-green-mid"
      >
        Start the Conversation
      </a>
    </div>
  </div>

</BaseLayout>
