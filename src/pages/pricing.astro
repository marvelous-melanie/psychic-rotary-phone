---
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
import { withBase } from '../lib/paths';
---

<MarketingPageLayout title="Pricing" description="Session packages and pricing for New Haven photography sessions.">
  <section class="mx-auto max-w-6xl px-4 py-14">
    <p class="text-xs uppercase tracking-[0.28em] text-muted">Session Options</p>
    <h1 class="mt-3 text-5xl">PRICING</h1>
    <p class="mt-4 max-w-2xl text-sm text-muted">
      Three thoughtful options designed for engagement and milestone sessions in New Haven and beyond.
    </p>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      <article class="rounded-sm border border-green-mid bg-cream px-6 py-8">
        <h2 class="text-2xl">The Essential</h2>
        <p class="mt-4 text-4xl text-green-deep">$350</p>
        <ul class="mt-5 space-y-2 text-sm text-muted">
          <li>1-hour session</li>
          <li>30 edited digital photos</li>
          <li>Online gallery delivery</li>
          <li>Personal print release</li>
        </ul>
      </article>

      <article class="relative overflow-hidden rounded-sm border-2 border-gold bg-green-deep px-6 py-8 text-cream">
        <span class="absolute right-0 top-0 bg-gold px-4 py-1 text-xs uppercase tracking-[0.24em] text-green-deep">Most Popular</span>
        <h2 class="text-2xl">The Story</h2>
        <p class="mt-4 text-4xl text-cream">$650</p>
        <ul class="mt-5 space-y-2 text-sm text-green-light">
          <li>2-hour session</li>
          <li>75+ edited digital photos</li>
          <li>Online gallery delivery</li>
          <li>Personal print release</li>
          <li>One 5×7 print included</li>
        </ul>
      </article>

      <article class="rounded-sm border border-green-mid bg-cream px-6 py-8">
        <h2 class="text-2xl">The Full Day</h2>
        <p class="mt-4 text-4xl text-green-deep">$1,100</p>
        <ul class="mt-5 space-y-2 text-sm text-muted">
          <li>Up to 6 hours</li>
          <li>150+ edited digital photos</li>
          <li>Online gallery delivery</li>
          <li>Personal print release</li>
          <li>8×10 framed print included</li>
          <li>Second location included</li>
        </ul>
      </article>
    </div>

    <p class="mt-8 text-sm text-muted">
      All packages include travel within the New Haven, CT area. Reach out for custom requests.
    </p>
    <a
      href={withBase('/contact/')}
      class="mt-6 inline-flex items-center rounded-sm bg-green-deep px-7 py-3 text-sm uppercase tracking-[0.2em] text-cream transition-colors hover:bg-green-mid"
    >
      Book a Session →
    </a>
  </section>
</MarketingPageLayout>
