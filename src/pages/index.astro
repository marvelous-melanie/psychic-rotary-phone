---
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/paths';
import { getGalleryCover } from '../lib/galleries';
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
import aboutPhoto from '../assets/about-photo.jpg';
import hero0004 from '../assets/galleries/engagements-2026/0004.jpg';
import hero0005 from '../assets/galleries/engagements-2026/0005.jpg';
import hero0006 from '../assets/galleries/engagements-2026/0006.jpg';
import hero0007 from '../assets/galleries/engagements-2026/0007.jpg';
import hero0008 from '../assets/galleries/engagements-2026/0008.jpg';
import hero0009 from '../assets/galleries/engagements-2026/0009.jpg';
import hero0011 from '../assets/galleries/engagements-2026/0011.jpg';
import hero0016 from '../assets/galleries/engagements-2026/0016.jpg';

const galleryMeta = await getCollection('galleries');
const engagementGallery = galleryMeta.find((gallery) => gallery.id === 'engagements-2026');
const graduationGallery = galleryMeta.find((gallery) => gallery.id === 'graduations-2026');
const engagementCover = engagementGallery ? getGalleryCover(engagementGallery.id, engagementGallery.data.cover) : null;
const graduationCover = graduationGallery ? getGalleryCover(graduationGallery.id, graduationGallery.data.cover) : null;

const heroSlides = (
  await Promise.all([
    getImage({ src: hero0004, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0005, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0006, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0007, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0008, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0009, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0011, width: 2400, format: 'webp', quality: 82 }),
    getImage({ src: hero0016, width: 2400, format: 'webp', quality: 82 }),
  ])
).map((image) => image.src);

const heroCaptions = [
  'LOVE DOCUMENTED IN NEW HAVEN & BEYOND',
  'MOMENTS FOR THE HEART',
  'LIFE’S TENDER INSTANCES',
  'WEDDING-LIKE INTIMACY IN EVERY LOOK',
  'NATURAL LIGHT, LASTING MEMORY',
  'TIMELESS PORTRAITS BY THE WATER',
  'SOFT LIGHT, SINCERE JOY',
  'THE DAY YOU LIVE FOR',
];
---

<MarketingPageLayout title="Elm City Photography" description="Placeholder marketing homepage for Elm City Photography.">
  <section class="relative w-full overflow-hidden" style="height: 70vh">
    {heroSlides.map((slide, index) => (
      <img
        src={slide}
        alt={heroCaptions[index] || 'Elm City Photography engagement session'}
        class:list={[
          'absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ease-in-out',
          index === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        data-hero-slide={index === 0 ? 'true' : 'false'}
      />
    ))}
    <div class="absolute inset-0 bg-green-deep/35"></div>
    <div class="relative z-10 flex h-full items-center justify-center px-6 text-center">
      <p class="max-w-4xl text-3xl uppercase tracking-[0.3em] text-cream md:text-5xl">
        LOVE DOCUMENTED IN NEW HAVEN &amp; BEYOND
      </p>
    </div>
  </section>

  <section class="mt-8 bg-green-deep px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-5xl text-cream">PORTFOLIO</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <a
          href={withBase('/engagements/')}
          class="group relative block h-96 overflow-hidden rounded-sm border border-green-light/30 bg-green-mid"
        >
          {engagementCover ? (
            <Image
              src={engagementCover.image}
              alt={engagementCover.alt}
              width={1200}
              height={800}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          ) : null}
          <div class="absolute inset-0 flex items-end bg-gradient-to-t from-green-deep/75 to-black/0 p-6">
            <h3 class="text-3xl text-cream">Engagements</h3>
          </div>
        </a>
        <a
          href={withBase('/graduations/')}
          class="group relative block h-96 overflow-hidden rounded-sm border border-green-light/30 bg-green-mid"
        >
          {graduationCover ? (
            <Image
              src={graduationCover.image}
              alt={graduationCover.alt}
              width={1200}
              height={800}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          ) : null}
          <div class="absolute inset-0 flex items-end bg-gradient-to-t from-green-deep/75 to-black/0 p-6">
            <h3 class="text-3xl text-cream">Graduations</h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-6xl px-4">
    <div class="grid gap-8 items-center md:grid-cols-[1.05fr_0.95fr]">
      <Image
        src={aboutPhoto}
        alt="Couple on coastal cliffs at sunset"
        width={853}
        height={1280}
        loading="lazy"
        class="h-full w-full object-cover"
      />
      <div>
        <p class="text-sm uppercase tracking-[0.24em] text-muted">About Elm City Photography</p>
        <h2 class="mt-2 text-4xl text-ink">ABOUT THE PHOTOGRAPHER</h2>
        <p class="mt-4 text-sm leading-7 text-muted">
          We are a New Haven, CT-based team focused on intimate, heartfelt photography for life’s meaningful milestones. Our
          lens seeks the quiet
          moments that make weddings, graduations, and portraits feel expansive.
        </p>
        <a
          href={withBase('/about/')}
          class="mt-5 inline-flex items-center text-sm uppercase tracking-[0.2em] text-green-deep underline decoration-green-mid hover:text-green-mid"
        >
          Learn More →
        </a>
      </div>
    </div>
  </section>

  <section class="mt-16 bg-cream px-4 py-14">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.28em] text-muted">Investment</p>
      <h2 class="mt-3 text-4xl">INVESTMENT</h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm text-muted">
        Thoughtfully designed coverage packages for modern celebrations, with full gallery delivery and editorial styling.
      </p>
      <a
        href={withBase('/pricing/')}
        class="mt-7 inline-flex items-center rounded-sm bg-green-deep px-7 py-3 text-sm uppercase tracking-[0.2em] text-cream transition-colors hover:bg-green-mid"
      >
        View Packages →
      </a>
    </div>
  </section>

  <section class="mt-2 bg-green-deep px-4 py-14">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-4xl text-cream md:text-5xl">LET&apos;S CREATE SOMETHING BEAUTIFUL</p>
      <a
        href="mailto:hello@elmcityphotography.com"
        class="mt-6 inline-block text-xl font-light tracking-[0.16em] text-cream underline decoration-gold underline-offset-4"
      >
        hello@elmcityphotography.com
      </a>
    </div>
  </section>
</MarketingPageLayout>

<script>
  const slides = Array.from(document.querySelectorAll('[data-hero-slide]'));
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      const next = (current + 1) % slides.length;
      slides.forEach((slide, index) => {
        slide.classList.toggle('opacity-100', index === next);
        slide.classList.toggle('opacity-0', index !== next);
      });
      current = next;
    }, 5000);
  }
</script>
