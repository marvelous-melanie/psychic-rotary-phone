---
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/paths';
import { getGalleryCover } from '../lib/galleries';
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutPhoto from '../assets/about-photo.jpg';
import hero0012 from '../assets/galleries/engagements-2026/0012.jpg';
import hero0005 from '../assets/galleries/engagements-2026/0005.jpg';
import hero0004 from '../assets/galleries/engagements-2026/0004.jpg';
import hero0002 from '../assets/galleries/engagements-2026/0002.jpg';

const heroSlides = await Promise.all([
  getImage({ src: hero0012, width: 2400, format: 'webp', quality: 85 }),
  getImage({ src: hero0005, width: 2400, format: 'webp', quality: 85 }),
  getImage({ src: hero0004, width: 2400, format: 'webp', quality: 85 }),
  getImage({ src: hero0002, width: 2400, format: 'webp', quality: 85 }),
]);

const galleries = await getCollection('galleries');
const engagements = galleries.find((g) => g.id === 'engagements-2026');
const graduations = galleries.find((g) => g.id === 'graduations-2026');
const engagementCover = engagements ? getGalleryCover(engagements.id, engagements.data.cover) : null;
const graduationCover  = graduations  ? getGalleryCover(graduations.id,  graduations.data.cover)  : null;

const testimonials = [
  {
    quote: "Working with Elm City Photography was the best decision we made for our entire wedding. They captured moments we didn't even know were happening: the look my grandmother gave during the vows, the way my husband laughed right before our first dance. We still ugly-cry looking through the gallery.",
    name: "Sofia & Marco",
    detail: "Wedding, Lighthouse Point Park, New Haven",
  },
  {
    quote: "I genuinely hate being photographed. Like, will leave the room hate it. But our engagement session felt like a walk with a friend who happened to have a camera. The photos don't look like us trying to look good. They just look like us.",
    name: "Jamie & Tess",
    detail: "Engagement Session, East Rock, New Haven",
  },
  {
    quote: "From our first email to the gallery delivery, everything was thoughtful and professional. Our photos are hanging all over the house now. We get compliments on them constantly. People always ask who the photographer was.",
    name: "Priya & Daniel",
    detail: "Wedding, New Haven County",
  },
];
---

<BaseLayout
  title="Elm City Photography | Wedding & Portrait Photographer, New Haven CT"
  description="Wedding, engagement, and portrait photography rooted in New Haven, CT. Natural light, honest moments, and images you'll keep for a lifetime."
  heroPreload={heroSlides[0].src}
>

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="relative w-full overflow-hidden h-[67vw] sm:h-screen sm:min-h-[560px]" aria-label="Hero">
    {heroSlides.map((slide, i) => (
      <img
        src={slide.src}
        alt=""
        role="presentation"
        class:list={[
          'absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ease-in-out',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        data-hero-slide
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    ))}
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-green-deep/15 via-transparent to-green-deep/60"></div>
    <div class="absolute inset-x-0 bottom-0 flex flex-col items-center pb-16 text-center">
      <p class="text-xs uppercase tracking-[0.38em] text-cream/70">New Haven, Connecticut</p>
      <h1 class="mt-3 font-serif text-4xl italic leading-snug text-cream md:text-6xl">
        Love captured in every light.
      </h1>
      <div class="mt-8 flex gap-2" role="tablist" aria-label="Hero slides">
        {heroSlides.map((_, i) => (
          <button
            type="button"
            role="tab"
            aria-label={`Slide ${i + 1}`}
            data-hero-dot={i}
            class:list={[
              'h-0.5 rounded-full transition-all duration-300',
              i === 0 ? 'w-8 bg-cream' : 'w-4 bg-cream/40',
            ]}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── INTRO ─────────────────────────────────────────────────────── -->
  <section class="bg-cream px-6 py-24 text-center">
    <div class="mx-auto max-w-xl">
      <p class="text-xs uppercase tracking-[0.38em] text-muted">Elm City Photography</p>
      <h2 class="mt-5 font-serif text-3xl italic leading-relaxed text-ink md:text-4xl">
        We photograph weddings, engagements, and milestones for people who want images that feel real.
      </h2>
      <p class="mt-6 text-base leading-8 text-muted">
        Based in New Haven, CT. Available for weddings and portrait sessions throughout Connecticut, New England, and beyond.
      </p>
    </div>
  </section>

  <!-- ── PORTFOLIO SPREAD ──────────────────────────────────────────── -->
  <section>
    <div class="flex h-[65vh] min-h-[360px] w-full">
      <a href={withBase('/engagements/')} class="group relative flex-1 overflow-hidden">
        {engagementCover && (
          <Image
            src={engagementCover.image}
            alt="Engagement photography by Elm City Photography"
            width={1200}
            height={900}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-green-deep/70 via-green-deep/10 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-8 md:p-12">
          <p class="text-xs uppercase tracking-[0.3em] text-green-light/80">Portfolio</p>
          <h3 class="mt-1 font-serif text-3xl italic text-cream md:text-4xl">Engagements</h3>
        </div>
      </a>
      <div class="w-px bg-cream/10"></div>
      <a href={withBase('/graduations/')} class="group relative flex-1 overflow-hidden">
        {graduationCover && (
          <Image
            src={graduationCover.image}
            alt="Graduation portrait photography by Elm City Photography"
            width={1200}
            height={900}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-green-deep/70 via-green-deep/10 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-8 md:p-12">
          <p class="text-xs uppercase tracking-[0.3em] text-green-light/80">Portfolio</p>
          <h3 class="mt-1 font-serif text-3xl italic text-cream md:text-4xl">Graduations</h3>
        </div>
      </a>
    </div>
  </section>

  <!-- ── ABOUT TEASER ──────────────────────────────────────────────── -->
  <section class="bg-cream" aria-labelledby="about-heading">
    <div class="mx-auto grid max-w-7xl items-center md:grid-cols-[5fr_6fr]">
      <div class="aspect-[3/4] overflow-hidden md:max-h-[640px]">
        <Image
          src={aboutPhoto}
          alt="Couple walking along coastal cliffs at golden hour"
          width={680}
          height={900}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="px-10 py-16 md:px-16 md:py-24">
        <p class="text-xs uppercase tracking-[0.35em] text-muted">About Us</p>
        <h2 id="about-heading" class="mt-4 font-serif text-4xl italic leading-tight text-ink md:text-5xl">
          We show up for<br />the small moments.
        </h2>
        <p class="mt-6 max-w-prose text-base leading-8 text-muted">
          We're a New Haven-based photography team that believes the best images come from genuine connection,
          not direction. Our approach is calm, unhurried, and built around you. We'll follow the light,
          give you space to breathe, and capture the moments you'll actually want to remember.
        </p>
        <p class="mt-4 max-w-prose text-base leading-8 text-muted">
          We photograph weddings, engagements, graduations, and portraits throughout Connecticut and New England.
          If you're planning something meaningful, we'd love to be there.
        </p>
        <a
          href={withBase('/about/')}
          class="mt-8 inline-flex items-center gap-2 text-xs uppercase tracking-[0.26em] text-ink transition-colors hover:text-green-mid"
        >
          Our Story <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ──────────────────────────────────────────────── -->
  <section class="bg-cream px-6 py-24" aria-labelledby="testimonials-heading">
    <div class="mx-auto max-w-5xl">
      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.38em] text-muted">Kind Words</p>
        <h2 id="testimonials-heading" class="mt-4 font-serif text-4xl italic text-ink md:text-5xl">What couples are saying.</h2>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {testimonials.map((t) => (
          <figure class="flex flex-col">
            <div class="mb-5 text-2xl text-green-light" aria-hidden="true">"</div>
            <blockquote class="flex-1 text-base leading-8 text-muted">
              <p>{t.quote}</p>
            </blockquote>
            <figcaption class="mt-8 border-t border-green-light/40 pt-6">
              <p class="font-serif italic text-ink">{t.name}</p>
              <p class="mt-1 text-xs uppercase tracking-[0.22em] text-muted/70">{t.detail}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INVESTMENT TEASER ─────────────────────────────────────────── -->
  <section class="bg-green-deep py-28 text-center" aria-labelledby="pricing-heading">
    <p class="text-xs uppercase tracking-[0.38em] text-green-light/70">Pricing</p>
    <h2 id="pricing-heading" class="mt-5 font-serif text-5xl italic text-cream md:text-6xl">
      Wedding coverage from $1,400.
    </h2>
    <p class="mx-auto mt-5 max-w-sm text-sm text-green-light/70">
      Full-day wedding packages include a second photographer. Portrait and engagement sessions available separately.
    </p>
    <a
      href={withBase('/pricing/')}
      class="mt-10 inline-block border-b border-gold/60 pb-px text-xs uppercase tracking-[0.3em] text-gold transition-colors hover:border-gold"
    >
      View Packages →
    </a>
  </section>

  <!-- ── CONTACT CTA ───────────────────────────────────────────────── -->
  <section class="bg-cream py-32 text-center" aria-labelledby="contact-heading">
    <p class="text-xs uppercase tracking-[0.38em] text-muted">Let's Connect</p>
    <h2 id="contact-heading" class="mt-5 font-serif text-5xl italic leading-tight text-ink md:text-6xl lg:text-7xl">
      Let's make<br />something beautiful.
    </h2>
    <p class="mx-auto mt-6 max-w-sm text-base leading-7 text-muted">
      We'd love to hear about your wedding, your engagement, or whatever milestone is coming up. Drop us a note. We get back to everyone.
    </p>
    <a
      href="mailto:hello@elmcityphotography.com"
      class="mt-8 inline-block text-sm text-muted underline underline-offset-4 transition-colors hover:text-ink"
    >
      hello@elmcityphotography.com
    </a>
  </section>

</BaseLayout>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-slide]'));
  const dots   = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-dot]'));

  if (slides.length > 1) {
    let current = 0;

    function goTo(next: number) {
      slides[current].classList.replace('opacity-100', 'opacity-0');
      dots[current].classList.replace('w-8', 'w-4');
      dots[current].classList.replace('bg-cream', 'bg-cream/40');

      slides[next].classList.replace('opacity-0', 'opacity-100');
      dots[next].classList.replace('w-4', 'w-8');
      dots[next].classList.replace('bg-cream/40', 'bg-cream');

      current = next;
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    setInterval(() => goTo((current + 1) % slides.length), 5000);
  }
</script>
