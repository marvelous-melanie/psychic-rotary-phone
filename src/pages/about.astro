---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutPhoto from '../assets/about-photo.jpg';
import { withBase } from '../lib/paths';
---

<BaseLayout
  title="Wedding Photographer New Haven CT | Our Story | Elm City Photography"
  description="Meet Elm City Photography — a wedding and portrait studio based in New Haven, CT, serving couples across Connecticut and New England."
>

  <div class="relative h-[72vh] min-h-[440px] w-full overflow-hidden">
    <Image
      src={aboutPhoto}
      alt="Two photographers reviewing a shot together on camera"
      width={1600}
      height={900}
      class="h-full w-full object-cover object-center"
      loading="eager"
    />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-green-deep/40"></div>
  </div>

  <section class="bg-cream">
    <div class="mx-auto max-w-2xl px-6 py-24 md:py-32">
      <p class="text-xs uppercase tracking-[0.38em] text-muted">About</p>
      <h1 class="mt-4 font-serif text-5xl italic leading-tight text-ink md:text-6xl">Our Story</h1>

      <p class="mt-10 text-base font-medium leading-8 text-ink">
        We're a small wedding and portrait photography studio based in New Haven, Connecticut. We photograph honestly and edit to match — colors that look like life, not like a filter.
      </p>

      <div class="mt-8 space-y-6 text-base leading-8 text-muted">
        <p>
          We started Elm City Photography because we believe the moments that matter most deserve to be preserved accurately.
          Not stiffly posed, not over-processed. Just real — the way your wedding actually looked, felt, and sounded
          when you were in the middle of it.
        </p>
        <p>
          Our editing approach is built around accurate, timeless color. We don't chase trends. Skin tones that look
          like your skin. Greens that look like the park you got married in. Images that won't feel dated when you
          pull them out in twenty years.
        </p>
        <p>
          We work mostly in available light and love locations with character: coastlines, city parks, old architecture,
          golden fields. We're based in New Haven and know every corner of this city and the surrounding Connecticut landscape.
        </p>
        <p>
          If you want photos that feel timeless but still look exactly like you — true colors, honest moments — we're
          probably the right fit.
        </p>
      </div>

      <div class="mt-14 border-t border-green-light/40 pt-10">
        <p class="text-xs uppercase tracking-[0.35em] text-muted">Ready to work together?</p>
        <a
          href={withBase('/contact/')}
          class="mt-4 inline-flex items-center gap-2 font-serif text-xl italic text-ink transition-colors hover:text-green-mid"
        >
          Get in touch <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
