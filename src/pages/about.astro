---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutPhoto from '../assets/about-photo.jpg';
import { withBase } from '../lib/paths';
---

<BaseLayout
  title="About | Elm City Photography"
  description="Elm City Photography is a wedding and portrait photography studio based in New Haven, CT."
>

  <div class="relative h-[72vh] min-h-[440px] w-full overflow-hidden">
    <Image
      src={aboutPhoto}
      alt="Couple walking hand in hand along coastal cliffs at golden hour"
      width={1280}
      height={853}
      class="h-full w-full object-cover object-center"
      loading="eager"
    />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-green-deep/40"></div>
  </div>

  <section class="bg-cream">
    <div class="mx-auto max-w-2xl px-6 py-24 md:py-32">
      <p class="text-xs uppercase tracking-[0.38em] text-muted">About</p>
      <h1 class="mt-4 font-serif text-5xl italic leading-tight text-ink md:text-6xl">Our Story</h1>

      <p class="mt-10 text-base font-medium leading-8 text-ink">
        We're a small wedding and portrait photography studio based in New Haven, Connecticut. And we genuinely love what we do.
      </p>

      <div class="mt-8 space-y-6 text-base leading-8 text-muted">
        <p>
          We started Elm City Photography because we believe that the moments that matter most deserve to be captured honestly.
          Not stiffly posed. Not over-directed. Just real, the way a wedding actually feels when you're in the middle of it,
          laughing too hard at a toast or tearing up during vows you wrote yourself.
        </p>
        <p>
          Our style is natural, warm, and editorial. We work mostly in available light, and we love locations that have
          character: coastlines, city parks, old architecture, golden fields. We're based in New Haven, which means
          we know every corner of this city and the surrounding Connecticut landscape, and we bring that familiarity
          to every session.
        </p>
        <p>
          We photograph weddings, engagements, graduations, and portrait sessions throughout Connecticut and New England.
          Whether you're planning an intimate elopement at the beach or a full celebration with two hundred guests,
          we approach every job with the same level of care and attention.
        </p>
        <p>
          If you're the kind of person who cares about images that feel like they could live in a magazine but still
          look exactly like you, we're probably the right fit. We're easy to work with, fast to respond,
          and genuinely invested in getting your photos right.
        </p>
      </div>

      <div class="mt-14 border-t border-green-light/40 pt-10">
        <p class="text-xs uppercase tracking-[0.35em] text-muted">Ready to work together?</p>
        <a
          href={withBase('/contact/')}
          class="mt-4 inline-flex items-center gap-2 font-serif text-xl italic text-ink transition-colors hover:text-green-mid"
        >
          Get in touch <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
